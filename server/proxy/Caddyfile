# Hardened TLS reverse proxy for the API (automatic Let's Encrypt certificates).
# Set DOMAIN and ACME_EMAIL in .env. Caddy obtains and renews certs automatically.
{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip

	# Security headers (TLS is on by default; HSTS opts browsers into HTTPS-only).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		Cross-Origin-Opener-Policy "same-origin"
		-Server
	}

	# Only the API is proxied; it listens on the private network, not the public internet.
	reverse_proxy api:8080
}
