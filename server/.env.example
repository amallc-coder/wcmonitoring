# ── Clinilytics — Wound Care API · environment ──
# Copy to .env and fill in. NEVER commit the real .env.
# Generate secrets:
#   key:    node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   secret: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"

# ─ Database passwords (used by docker-compose to build the cluster) ─
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
REPL_PASSWORD=CHANGE_ME_STRONG_REPLICATION_PASSWORD

# ─ App secrets ─
DATA_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_BASE64_KEY      # encrypts PHI at rest
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET               # signs session tokens
JWT_TTL_HOURS=12

# ─ CORS: your browser origin(s), comma-separated ─
CORS_ORIGIN=https://amallc-coder.github.io

# ─ Seed administrator (created on first boot; change password after) ─
ADMIN_USER=admin
ADMIN_PASS=CHANGE_ME_ON_FIRST_LOGIN
ADMIN_NAME=Clinilytics Administrator
ORG_NAME=Clinilytics

# ─ Ports / limits ─
API_PORT=8080
BODY_LIMIT=30mb

# ─ Timezone for scheduled emails (cron-style report times use this) ─
TZ=America/New_York

# ─ Email automation (SMTP) ─
# No env needed: configure SMTP in-app (Admin → Settings → Email & automation).
# Settings are stored encrypted in the DB. The scheduler runs in-process.

# ─ Backups ─
BACKUP_INTERVAL_SECONDS=21600   # every 6 hours
BACKUP_RETENTION=28             # keep newest 28 dumps

# ─ Bundled TLS reverse proxy (opt-in: docker compose --profile proxy up -d) ─
DOMAIN=api.yourdomain.com
ACME_EMAIL=ops@yourdomain.com

# ─ Key sources (alternatives to plaintext env — pick at most one each) ─
# Mounted secret files (Docker/K8s/secret manager):
# DATA_ENCRYPTION_KEY_FILE=/run/secrets/data_key
# JWT_SECRET_FILE=/run/secrets/jwt_secret
# AWS KMS envelope (needs: npm i @aws-sdk/client-kms):
# KMS_DATA_KEY_CIPHERTEXT=base64-of-kms-encrypted-32-byte-key
# KMS_KEY_ID=arn:aws:kms:us-east-1:...:key/...
# AWS_REGION=us-east-1

# ─ Claude AI — wound photo analysis + note drafting ─ (pick ONE provider)
# Leave all unset to keep AI OFF. Wound photos are PHI → use a BAA-covered path.
#
# Option 1 — Anthropic native (BAA required for PHI):
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages   # or a gateway
#
# Option 2 — AWS Bedrock (the usual BAA route; needs: npm i @aws-sdk/client-bedrock-runtime):
# BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-8-v1:0        # your enabled model / inference profile
# AWS_REGION=us-east-1
# (AWS credentials via the standard chain: IAM role on the host, or AWS_ACCESS_KEY_ID/SECRET)

# ─ Optional OpenAI-compatible fallback for note drafting only (no vision) ─
# AI_API_URL=https://YOUR-RESOURCE.openai.azure.com/openai/deployments/YOUR-DEPLOYMENT/chat/completions?api-version=2024-02-15-preview
# AI_API_KEY=your-provider-key
# AI_MODEL=gpt-4o-mini

# ─ Supabase (@supabase/server SDK) — copy real values from the dashboard's Connect dialog ─
# Never commit the secret key. On Supabase Edge Functions these are injected automatically.
# SUPABASE_URL=https://prvzcbyeuqlstqrlbbum.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...      # safe for clients
# SUPABASE_SECRET_KEY=sb_secret_...                # server-only — keep out of git
# SUPABASE_JWKS_URL=https://prvzcbyeuqlstqrlbbum.supabase.co/auth/v1/.well-known/jwks.json

# ─ Running the API WITHOUT docker-compose (standalone) ─
# Set this instead of DB_PASSWORD and point at your managed Postgres.
# DATABASE_URL=postgres://user:pass@host:5432/woundcare
# PGSSLMODE=require
