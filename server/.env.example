# ── Clinilytics — Wound Care API · environment ──
# Copy to .env and fill in. NEVER commit the real .env.
# Generate secrets:
#   key:    node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   secret: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"

# ─ Database passwords (used by docker-compose to build the cluster) ─
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
REPL_PASSWORD=CHANGE_ME_STRONG_REPLICATION_PASSWORD

# ─ App secrets ─
DATA_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_BASE64_KEY      # encrypts PHI at rest
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET               # signs session tokens
JWT_TTL_HOURS=12

# ─ CORS: your browser origin(s), comma-separated ─
CORS_ORIGIN=https://amallc-coder.github.io

# ─ Seed administrator (created on first boot; change password after) ─
ADMIN_USER=admin
ADMIN_PASS=CHANGE_ME_ON_FIRST_LOGIN
ADMIN_NAME=Clinilytics Administrator
ORG_NAME=Clinilytics

# ─ Ports / limits ─
API_PORT=8080
BODY_LIMIT=30mb

# ─ Backups ─
BACKUP_INTERVAL_SECONDS=21600   # every 6 hours
BACKUP_RETENTION=28             # keep newest 28 dumps

# ─ Bundled TLS reverse proxy (opt-in: docker compose --profile proxy up -d) ─
DOMAIN=api.yourdomain.com
ACME_EMAIL=ops@yourdomain.com

# ─ Key sources (alternatives to plaintext env — pick at most one each) ─
# Mounted secret files (Docker/K8s/secret manager):
# DATA_ENCRYPTION_KEY_FILE=/run/secrets/data_key
# JWT_SECRET_FILE=/run/secrets/jwt_secret
# AWS KMS envelope (needs: npm i @aws-sdk/client-kms):
# KMS_DATA_KEY_CIPHERTEXT=base64-of-kms-encrypted-32-byte-key
# KMS_KEY_ID=arn:aws:kms:us-east-1:...:key/...
# AWS_REGION=us-east-1

# ─ Running the API WITHOUT docker-compose (standalone) ─
# Set this instead of DB_PASSWORD and point at your managed Postgres.
# DATABASE_URL=postgres://user:pass@host:5432/woundcare
# PGSSLMODE=require
